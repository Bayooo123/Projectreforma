            "validation_rules": "nullable|string|max:255"
          },
          "name": {
            "description": "Internal name of the matter.",
            "validation_rules": "required|string|max:255"
          },
          "court": {
            "description": "Presiding court jurisdiction.",
            "validation_rules": "nullable|string|max:255"
          },
          "judge": {
            "description": "Presiding judge.",
            "validation_rules": "nullable|string|max:255"
          },
          "opponentName": {
            "description": "Opposing party.",
            "validation_rules": "nullable|string|max:255"
          },
          "opponentCounsel": {
            "description": "Counsel representing the opponent.",
            "validation_rules": "nullable|string|max:255"
          },
          "status": {
            "description": "Current status of the case.",
            "validation_rules": "required|in:active,closed,pending"
          },
          "nextCourtDate": {
            "description": "Next hearing or court date.",
            "validation_rules": "nullable|date"
