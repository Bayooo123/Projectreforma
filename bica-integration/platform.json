{
    "identity": {
        "platform_id": "reforma_os",
        "name": "Reforma Legal OS",
        "description": "Comprehensive legal practice management. Manage clients, matters, briefs, finances, and compliance with secure RBAC.",
        "version": "1.2.0"
    },
    "branding": {
        "logo_url": "https://reforma.ng/assets/logo-icon.png",
        "brand_color": "#121826",
        "accent_color": "#3182ce",
        "bot_name": "Reforma Assistant",
        "greeting_message": "Good morning. How can Reforma assist your practice and compliance needs today?",
        "suggested_prompts": [
            "View upcoming court dates",
            "Summarize meeting recordings",
            "Check pending compliance tasks",
            "Generate an invoice for Client X"
        ]
    },
    "knowledge": {
        "playbooks": [
            {
                "name": "Client",
                "description": "Represents an individual or organization served by the firm. Central entity for tracking all work.",
                "fields": {
                    "id": {
                        "description": "Unique identifier (CUID).",
                        "validation_rules": "prohibited"
                    },
                    "name": {
                        "description": "Full legal name of the client.",
                        "validation_rules": "required|string|max:255"
                    },
                    "email": {
                        "description": "Primary contact email.",
                        "validation_rules": "required|email|max:255"
                    },
                    "status": {
                        "description": "Relationship status.",
                        "validation_rules": "required|in:active,inactive"
                    }
                },
                "child_relationships": [
                    "Matter",
                    "Brief",
                    "Invoice",
                    "Task",
                    "CalendarEntry"
                ],
                "min_record_count": 0,
                "max_record_count": 10000,
                "preview_api_link": "https://app.reforma.ng/management/clients/{entity_id}"
            },
            {
                "name": "Matter",
                "description": "Represents a specific legal case or matter. Tracks court details and hearing schedules.",
                "fields": {
                    "id": {
                        "description": "Unique identifier (CUID).",
                        "validation_rules": "prohibited"
                    },
                    "caseNumber": {
                        "description": "Official court reference number.",
                        "validation_rules": "nullable|string|max:255"
                    },
                    "name": {
                        "description": "Internal name of the matter.",
                        "validation_rules": "required|string|max:255"
                    },
                    "court": {
                        "description": "Presiding court jurisdiction.",
                        "validation_rules": "nullable|string|max:255"
                    },
                    "status": {
                        "description": "Current status of the case.",
                        "validation_rules": "required|in:active,closed,pending"
                    }
                },
                "child_relationships": [
                    "Brief",
                    "CalendarEntry",
                    "Task",
                    "MeetingRecording",
                    "Invoice"
                ],
                "min_record_count": 0,
                "max_record_count": 5000,
                "preview_api_link": "https://app.reforma.ng/matters/{entity_id}"
            },
            {
                "name": "Brief",
                "description": "Formal legal document, assignment, or court-related task.",
                "fields": {
                    "id": {
                        "description": "Unique identifier (CUID).",
                        "validation_rules": "prohibited"
                    },
                    "briefNumber": {
                        "description": "System-generated unique identifier.",
                        "validation_rules": "prohibited"
                    },
                    "name": {
                        "description": "Title or subject of the brief.",
                        "validation_rules": "required|string|max:255"
                    },
                    "category": {
                        "description": "Legal category (e.g., Litigation, Advisory).",
                        "validation_rules": "required|string|max:100"
                    },
                    "status": {
                        "description": "Current workflow status.",
                        "validation_rules": "required|in:active,completed,pending,archived"
                    },
                    "dueDate": {
                        "description": "Deadline for completion.",
                        "validation_rules": "nullable|date"
                    }
                },
                "child_relationships": [
                    "Document",
                    "Task",
                    "CalendarEntry"
                ],
                "min_record_count": 0,
                "max_record_count": 20000,
                "preview_api_link": "https://app.reforma.ng/briefs/{entity_id}"
            },
            {
                "name": "CalendarEntry",
                "description": "An entry in the firm calendar representing hearings, court dates, or meetings.",
                "fields": {
                    "id": {
                        "description": "Unique identifier (CUID).",
                        "validation_rules": "prohibited"
                    },
                    "date": {
                        "description": "Scheduled date and time.",
                        "validation_rules": "required|date"
                    },
                    "type": {
                        "description": "Nature of the entry.",
                        "validation_rules": "required|in:COURT_DATE,FILING_DEADLINE,CLIENT_MEETING,INTERNAL_MEETING,OTHER"
                    },
                    "title": {
                        "description": "Brief title of the event.",
                        "validation_rules": "required|string|max:255"
                    },
                    "proceedings": {
                        "description": "Notes on what transpired.",
                        "validation_rules": "nullable|string"
                    },
                    "outcome": {
                        "description": "Visual summary of the result.",
                        "validation_rules": "nullable|string"
                    }
                },
                "child_relationships": [
                    "MeetingRecording"
                ],
                "min_record_count": 0,
                "max_record_count": 50000,
                "preview_api_link": "https://app.reforma.ng/calendar"
            },
            {
                "name": "Task",
                "description": "A general task or action item within a workspace.",
                "fields": {
                    "id": {
                        "description": "Unique identifier (CUID).",
                        "validation_rules": "prohibited"
                    },
                    "title": {
                        "description": "The task title.",
                        "validation_rules": "required|string|max:255"
                    },
                    "description": {
                        "description": "Detailed task instructions.",
                        "validation_rules": "nullable|string"
                    },
                    "status": {
                        "description": "Current status of the task.",
                        "validation_rules": "required|in:pending,in_progress,completed,on_hold"
                    },
                    "priority": {
                        "description": "Urgency level.",
                        "validation_rules": "required|in:low,medium,high,urgent"
                    },
                    "dueDate": {
                        "description": "Target completion date.",
                        "validation_rules": "nullable|date"
                    }
                },
                "child_relationships": [],
                "min_record_count": 0,
                "max_record_count": 100000,
                "preview_api_link": "https://app.reforma.ng/management/tasks"
            },
            {
                "name": "ComplianceTask",
                "description": "Monitoring and reporting task for regulatory compliance obligations.",
                "fields": {
                    "id": {
                        "description": "Unique identifier.",
                        "validation_rules": "prohibited"
                    },
                    "status": {
                        "description": "Compliance status.",
                        "validation_rules": "required|in:pending,concluded,overdue"
                    },
                    "dueDate": {
                        "description": "Regulatory deadline.",
                        "validation_rules": "nullable|date"
                    },
                    "period": {
                        "description": "Reporting period (e.g., Q1 2024).",
                        "validation_rules": "nullable|string"
                    },
                    "evidenceUrl": {
                        "description": "URL to uploaded proof of compliance.",
                        "validation_rules": "nullable|url"
                    }
                },
                "child_relationships": [],
                "min_record_count": 0,
                "max_record_count": 5000,
                "preview_api_link": "https://app.reforma.ng/management/compliance"
            },
            {
                "name": "MeetingRecording",
                "description": "Multimedia record and AI transcription of a meeting session.",
                "fields": {
                    "id": {
                        "description": "Unique identifier.",
                        "validation_rules": "prohibited"
                    },
                    "audioFileUrl": {
                        "description": "Reference to the stored audio file.",
                        "validation_rules": "nullable|url"
                    },
                    "transcriptText": {
                        "description": "Full AI transcription and summary.",
                        "validation_rules": "nullable|string"
                    },
                    "recordingDuration": {
                        "description": "Duration in seconds.",
                        "validation_rules": "nullable|integer|min:0"
                    }
                },
                "child_relationships": [],
                "min_record_count": 0,
                "max_record_count": 10000,
                "preview_api_link": "https://app.reforma.ng/matters/{matterId}"
            },
            {
                "name": "DraftingTemplate",
                "description": "Automation template for legal drafting and document assembly.",
                "fields": {
                    "id": {
                        "description": "Unique identifier.",
                        "validation_rules": "prohibited"
                    },
                    "name": {
                        "description": "Template name.",
                        "validation_rules": "required|string|max:255"
                    },
                    "category": {
                        "description": "Document category.",
                        "validation_rules": "required|string|max:100"
                    },
                    "isPublished": {
                        "description": "Whether the template is active for use.",
                        "validation_rules": "required|boolean"
                    }
                },
                "child_relationships": [],
                "min_record_count": 0,
                "max_record_count": 1000,
                "preview_api_link": "https://app.reforma.ng/drafting"
            },
            {
                "name": "Invoice",
                "description": "Billing record for legal services. Restricted to Admin/Partners.",
                "fields": {
                    "id": {
                        "description": "Unique identifier.",
                        "validation_rules": "prohibited"
                    },
                    "invoiceNumber": {
                        "description": "Unique reference number.",
                        "validation_rules": "prohibited"
                    },
                    "status": {
                        "description": "Payment status.",
                        "validation_rules": "required|in:pending,paid,overdue,cancelled"
                    },
                    "totalAmount": {
                        "description": "Total amount due in kobo.",
                        "validation_rules": "required|integer|min:0"
                    }
                },
                "child_relationships": [
                    "Payment"
                ],
                "min_record_count": 0,
                "max_record_count": 10000,
                "preview_api_link": "https://app.reforma.ng/management/office/invoices/{entity_id}"
            },
            {
                "name": "Payment",
                "description": "Record of financial transaction received. Restricted to Finance/Admin.",
                "fields": {
                    "id": {
                        "description": "Unique identifier.",
                        "validation_rules": "prohibited"
                    },
                    "amount": {
                        "description": "Amount received in kobo.",
                        "validation_rules": "required|integer|min:0"
                    },
                    "method": {
                        "description": "Mode of payment.",
                        "validation_rules": "required|string|max:50"
                    },
                    "date": {
                        "description": "Date received.",
                        "validation_rules": "required|date"
                    }
                },
                "child_relationships": [],
                "min_record_count": 0,
                "max_record_count": 50000,
                "preview_api_link": "https://app.reforma.ng/management/office/payments/{entity_id}"
            }
        ],
        "protocols": [
            {
                "title": "RBAC Verification",
                "content": "Before any financial mutation (Invoice/Payment) or sensitive record deletion, Bica must explicitly confirm the user has 'Admin' or 'Finance' role clearance."
            },
            {
                "title": "Conflict of Interest Check",
                "content": "When creating a new Client, Bica must search for existing records with identical or phonetically similar names and flag potential duplicates to the user."
            },
            {
                "title": "Relationship Integrity",
                "content": "Every Brief must be strictly linked to a parent Client. Matters should be associated with parent Clients before any court dates or recordings follow."
            },
            {
                "title": "Compliance Monitoring",
                "content": "When querying for deadlines, Bica should cross-reference ComplianceTasks alongside court dates to provide a unified risk view for the firm."
            }
        ],
        "model_parentage_map": {
            "Client": [
                "Matter",
                "Brief",
                "Invoice",
                "Task",
                "CalendarEntry"
            ],
            "Matter": [
                "Brief",
                "CalendarEntry",
                "Task",
                "MeetingRecording",
                "Invoice"
            ],
            "Brief": [
                "Task",
                "CalendarEntry"
            ],
            "CalendarEntry": [
                "MeetingRecording"
            ],
            "Invoice": [
                "Payment"
            ],
            "Workspace": [
                "ComplianceTask",
                "DraftingTemplate"
            ]
        }
    },
    "endpoints": {
        "base_url": "https://api.reforma.ng/api",
        "execute_path": "/bica/execute",
        "auth_type": "hmac_sha256",
        "timeout_ms": 30000,
        "entry": {
            "session_generation_url": "https://api.reforma.ng/api/bica/sessions"
        }
    },
    "conversation": {
        "max_messages": 50
    }
}