# Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Authentication
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Cron Jobs
CRON_SECRET="generate-with-openssl-rand-base64-32"

# BICA Integration
# Set to 'true' in development to easily test BICA execute route without HMAC
# MUST BE omitted or set to 'false' in production
BICA_DISABLE_HMAC="false"