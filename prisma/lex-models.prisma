// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ... (keeping all existing models)

// ============================================
// LEX AI ASSISTANT MODELS
// ============================================

model LexConversation {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  title       String?  // Optional conversation title
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages LexMessage[]
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

model LexMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // 'user' | 'assistant' | 'system'
  content        String   @db.Text
  functionCalls  Json?    // Store function calls and results
  createdAt      DateTime @default(now())

  conversation LexConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
